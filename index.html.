index.html.<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Abraham Dogbo — Spécialiste Marketing Digital & IA</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/lucide/0.263.1/lucide.min.css" />

  <style>
    /* ============================================================
       RESET & BASE
    ============================================================ */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; font-size: 16px; }
    body {
      font-family: 'Inter', system-ui, sans-serif;
      color: #1e293b;
      background: #ffffff;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }
    img { max-width: 100%; display: block; }
    a { text-decoration: none; color: inherit; }
    button { cursor: pointer; border: none; background: none; font-family: inherit; }
    ul { list-style: none; }

    /* ============================================================
       CSS CUSTOM PROPERTIES
    ============================================================ */
    :root {
      --navy-50:  #eef2ff;
      --navy-100: #e0e7ff;
      --navy-500: #1e3a5f;
      --navy-600: #162d4a;
      --navy-700: #0f1f35;
      --navy-800: #0a1628;
      --navy-900: #050e1a;
      --gold-400: #f0c040;
      --gold-500: #d4a017;
      --gold-600: #b8860b;
      --gray-50:  #f8fafc;
      --gray-100: #f1f5f9;
      --gray-200: #e2e8f0;
      --gray-400: #94a3b8;
      --gray-500: #64748b;
      --gray-600: #475569;
      --gray-700: #334155;
      --white:    #ffffff;
      --shadow-sm: 0 1px 3px rgba(0,0,0,.08), 0 1px 2px rgba(0,0,0,.04);
      --shadow-md: 0 4px 16px rgba(0,0,0,.10), 0 2px 6px rgba(0,0,0,.06);
      --shadow-lg: 0 10px 40px rgba(0,0,0,.14), 0 4px 12px rgba(0,0,0,.08);
      --shadow-xl: 0 20px 60px rgba(0,0,0,.18);
      --radius-sm: 8px;
      --radius-md: 12px;
      --radius-lg: 16px;
      --radius-xl: 24px;
      --radius-full: 9999px;
      --transition: all .3s cubic-bezier(.4,0,.2,1);
    }

    /* ============================================================
       SCROLLBAR
    ============================================================ */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: var(--gray-100); }
    ::-webkit-scrollbar-thumb { background: var(--navy-500); border-radius: var(--radius-full); }

    /* ============================================================
       UTILITY CLASSES
    ============================================================ */
    .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
    .section { padding: 96px 0; }
    .section--dark { background: var(--navy-800); }
    .section--gray { background: var(--gray-50); }
    .section--white { background: var(--white); }

    .section-label {
      display: inline-block;
      font-size: .75rem;
      font-weight: 600;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: var(--gold-500);
      margin-bottom: 12px;
    }
    .section-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.75rem, 4vw, 2.5rem);
      font-weight: 700;
      color: var(--navy-700);
      line-height: 1.2;
      margin-bottom: 16px;
    }
    .section-title .accent { color: var(--gold-500); }
    .section-desc { color: var(--gray-500); max-width: 540px; line-height: 1.7; }
    .text-center { text-align: center; }
    .text-center .section-desc { margin: 0 auto; }

    /* Buttons */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: .9rem;
      font-weight: 600;
      padding: 12px 28px;
      border-radius: var(--radius-md);
      transition: var(--transition);
      cursor: pointer;
      border: 2px solid transparent;
      white-space: nowrap;
    }
    .btn-primary {
      background: var(--gold-500);
      color: white;
      border-color: var(--gold-500);
    }
    .btn-primary:hover {
      background: var(--gold-600);
      border-color: var(--gold-600);
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(212,160,23,.35);
    }
    .btn-outline {
      background: transparent;
      color: white;
      border-color: rgba(255,255,255,.4);
    }
    .btn-outline:hover {
      background: white;
      color: var(--navy-700);
      border-color: white;
    }
    .btn-navy {
      background: var(--navy-700);
      color: white;
      border-color: var(--navy-700);
    }
    .btn-navy:hover { background: var(--navy-800); transform: translateY(-2px); }
    .btn-ghost {
      background: transparent;
      color: var(--navy-600);
      border-color: var(--navy-600);
    }
    .btn-ghost:hover { background: var(--navy-600); color: white; }
    .btn-sm { padding: 8px 18px; font-size: .8rem; }
    .btn-danger { background: #ef4444; color: white; border-color: #ef4444; }
    .btn-danger:hover { background: #dc2626; }

    /* Cards */
    .card {
      background: white;
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--gray-100);
      transition: var(--transition);
      overflow: hidden;
    }
    .card:hover { box-shadow: var(--shadow-lg); transform: translateY(-4px); }

    /* Badge */
    .badge {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 4px 12px;
      border-radius: var(--radius-full);
      font-size: .75rem;
      font-weight: 600;
      white-space: nowrap;
    }
    .badge-gray { background: var(--gray-100); color: var(--gray-600); }
    .badge-gold { background: rgba(212,160,23,.12); color: var(--gold-600); }
    .badge-navy { background: rgba(14,31,53,.08); color: var(--navy-600); }
    .badge-green { background: #dcfce7; color: #15803d; }
    .badge-blue  { background: #dbeafe; color: #1d4ed8; }
    .badge-purple{ background: #f3e8ff; color: #7c3aed; }
    .badge-red   { background: #fee2e2; color: #b91c1c; }

    /* Grid helpers */
    .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
    .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
    .flex { display: flex; }
    .flex-wrap { flex-wrap: wrap; }
    .items-center { align-items: center; }
    .justify-center { justify-content: center; }
    .gap-2 { gap: 8px; }
    .gap-3 { gap: 12px; }
    .gap-4 { gap: 16px; }

    /* Form */
    .form-group { margin-bottom: 18px; }
    .form-label {
      display: block;
      font-size: .85rem;
      font-weight: 500;
      color: var(--gray-700);
      margin-bottom: 6px;
    }
    .form-input, .form-select, .form-textarea {
      width: 100%;
      padding: 12px 16px;
      border: 1.5px solid var(--gray-200);
      border-radius: var(--radius-md);
      font-family: inherit;
      font-size: .9rem;
      color: var(--gray-700);
      background: var(--gray-50);
      transition: var(--transition);
      outline: none;
    }
    .form-input:focus, .form-select:focus, .form-textarea:focus {
      border-color: var(--gold-500);
      background: white;
      box-shadow: 0 0 0 3px rgba(212,160,23,.12);
    }
    .form-textarea { resize: vertical; min-height: 140px; }

    /* Alert */
    .alert {
      padding: 12px 16px;
      border-radius: var(--radius-md);
      font-size: .875rem;
      display: flex;
      align-items: center;
      gap: 8px;
      margin-top: 12px;
    }
    .alert-success { background: #dcfce7; color: #15803d; border: 1px solid #bbf7d0; }
    .alert-error   { background: #fee2e2; color: #b91c1c; border: 1px solid #fecaca; }
    .alert-info    { background: #fffbeb; color: #92400e; border: 1px solid #fde68a; }

    /* Progress bar */
    .progress-bar-container {
      height: 8px;
      background: var(--gray-100);
      border-radius: var(--radius-full);
      overflow: hidden;
    }
    .progress-bar {
      height: 100%;
      border-radius: var(--radius-full);
      transition: width 1s ease;
    }

    /* Reveal animation */
    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity .65s ease, transform .65s ease;
    }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    .reveal-delay-1 { transition-delay: .1s; }
    .reveal-delay-2 { transition-delay: .2s; }
    .reveal-delay-3 { transition-delay: .3s; }
    .reveal-delay-4 { transition-delay: .4s; }

    /* ============================================================
       NAVBAR
    ============================================================ */
    #navbar {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      transition: var(--transition);
      padding: 0 24px;
    }
    #navbar.scrolled {
      background: rgba(255,255,255,.96);
      backdrop-filter: blur(12px);
      box-shadow: 0 1px 20px rgba(0,0,0,.08);
    }
    .nav-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 70px;
    }
    .nav-logo {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .nav-logo-icon {
      width: 38px; height: 38px;
      background: linear-gradient(135deg, var(--navy-600), var(--navy-800));
      border-radius: var(--radius-sm);
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-size: 18px;
      font-weight: 700;
      transition: var(--transition);
    }
    .nav-logo:hover .nav-logo-icon {
      background: linear-gradient(135deg, var(--gold-500), var(--gold-600));
    }
    .nav-logo-text {
      font-family: 'Playfair Display', serif;
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--navy-700);
    }
    .nav-logo-text span { color: var(--gold-500); }
    .nav-links {
      display: flex;
      align-items: center;
      gap: 32px;
    }
    .nav-link {
      font-size: .9rem;
      font-weight: 500;
      color: var(--gray-600);
      position: relative;
      padding-bottom: 2px;
      transition: color .2s;
    }
    .nav-link::after {
      content: '';
      position: absolute;
      bottom: -2px; left: 0;
      width: 0; height: 2px;
      background: var(--gold-500);
      border-radius: var(--radius-full);
      transition: width .3s ease;
    }
    .nav-link:hover, .nav-link.active {
      color: var(--navy-700);
    }
    .nav-link:hover::after, .nav-link.active::after { width: 100%; }
    .nav-cta { display: flex; align-items: center; gap: 12px; }
    .nav-admin-link {
      font-size: .75rem;
      color: var(--gray-400);
      transition: color .2s;
    }
    .nav-admin-link:hover { color: var(--navy-500); }
    .nav-hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      padding: 4px;
    }
    .nav-hamburger span {
      display: block;
      width: 24px; height: 2px;
      background: var(--navy-700);
      border-radius: var(--radius-full);
      transition: var(--transition);
    }
    .nav-hamburger.open span:nth-child(1) { transform: rotate(45deg) translate(5px,5px); }
    .nav-hamburger.open span:nth-child(2) { opacity: 0; }
    .nav-hamburger.open span:nth-child(3) { transform: rotate(-45deg) translate(5px,-5px); }
    .nav-mobile {
      display: none;
      background: white;
      border-top: 1px solid var(--gray-100);
      padding: 16px 24px 24px;
    }
    .nav-mobile a {
      display: block;
      padding: 10px 0;
      color: var(--gray-600);
      font-weight: 500;
      border-bottom: 1px solid var(--gray-100);
      transition: color .2s;
    }
    .nav-mobile a:hover { color: var(--gold-500); }
    .nav-mobile a:last-child { border: none; }

    /* ============================================================
       HERO
    ============================================================ */
    #hero {
      min-height: 100vh;
      background: linear-gradient(135deg, var(--navy-900) 0%, var(--navy-700) 50%, var(--navy-800) 100%);
      display: flex;
      align-items: center;
      position: relative;
      overflow: hidden;
    }
    .hero-bg-grid {
      position: absolute;
      inset: 0;
      opacity: .04;
      background-image:
        linear-gradient(rgba(255,255,255,.3) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.3) 1px, transparent 1px);
      background-size: 60px 60px;
      pointer-events: none;
    }
    .hero-blob-1 {
      position: absolute;
      top: -160px; right: -160px;
      width: 480px; height: 480px;
      background: rgba(212,160,23,.1);
      border-radius: 50%;
      filter: blur(80px);
      pointer-events: none;
    }
    .hero-blob-2 {
      position: absolute;
      bottom: -160px; left: -160px;
      width: 480px; height: 480px;
      background: rgba(59,130,246,.08);
      border-radius: 50%;
      filter: blur(80px);
      pointer-events: none;
    }
    .hero-inner {
      position: relative;
      z-index: 2;
      max-width: 1100px;
      margin: 0 auto;
      padding: 120px 24px 80px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 64px;
      align-items: center;
    }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(212,160,23,.15);
      border: 1px solid rgba(212,160,23,.3);
      color: var(--gold-400);
      padding: 6px 16px;
      border-radius: var(--radius-full);
      font-size: .8rem;
      font-weight: 500;
      margin-bottom: 24px;
    }
    .hero-badge-dot {
      width: 7px; height: 7px;
      background: var(--gold-400);
      border-radius: 50%;
      animation: pulse-dot 2s ease infinite;
    }
    @keyframes pulse-dot {
      0%,100% { opacity: 1; transform: scale(1); }
      50% { opacity: .5; transform: scale(.8); }
    }
    .hero-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2.2rem, 5vw, 3.5rem);
      font-weight: 700;
      color: white;
      line-height: 1.15;
      margin-bottom: 16px;
    }
    .hero-title .name-accent { color: var(--gold-400); }
    .hero-typewriter {
      font-size: 1.25rem;
      color: rgba(255,255,255,.75);
      margin-bottom: 8px;
      min-height: 2rem;
    }
    .typewriter-word { color: var(--gold-400); font-weight: 700; }
    .typewriter-cursor {
      display: inline-block;
      animation: blink .75s step-end infinite;
    }
    @keyframes blink { 0%,100% { opacity:1; } 50% { opacity:0; } }
    .hero-desc {
      color: rgba(255,255,255,.6);
      font-size: 1rem;
      line-height: 1.8;
      margin: 20px 0 32px;
      max-width: 460px;
    }
    .hero-desc .hl-marketing { color: var(--gold-400); font-weight: 600; }
    .hero-desc .hl-ia { color: #60a5fa; font-weight: 600; }
    .hero-desc .hl-droit { color: #4ade80; font-weight: 600; }
    .hero-cta { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 40px; }
    .hero-stats { display: flex; gap: 28px; flex-wrap: wrap; }
    .hero-stat {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .hero-stat-icon {
      width: 42px; height: 42px;
      background: rgba(255,255,255,.08);
      border-radius: var(--radius-sm);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.2rem;
    }
    .hero-stat-value {
      font-size: 1.25rem;
      font-weight: 700;
      color: white;
      line-height: 1;
    }
    .hero-stat-label { font-size: .75rem; color: rgba(255,255,255,.45); }

    /* Photo area */
    .hero-photo-wrap { display: flex; justify-content: center; }
    .hero-photo-outer {
      position: relative;
      width: 320px; height: 320px;
    }
    .hero-photo-ring-1 {
      position: absolute;
      inset: -14px;
      border-radius: 50%;
      border: 2px solid rgba(212,160,23,.2);
      animation: spin-slow 20s linear infinite;
    }
    .hero-photo-ring-2 {
      position: absolute;
      inset: -28px;
      border-radius: 50%;
      border: 1px solid rgba(255,255,255,.06);
    }
    @keyframes spin-slow { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
    .hero-photo {
      width: 100%; height: 100%;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--navy-600), var(--navy-800));
      border: 4px solid rgba(212,160,23,.3);
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      text-align: center;
      color: rgba(255,255,255,.5);
      font-size: .85rem;
      box-shadow: var(--shadow-xl);
    }
    .hero-photo-emoji { font-size: 5rem; margin-bottom: 8px; }
    .hero-photo img { width: 100%; height: 100%; object-fit: cover; }
    .hero-float-badge {
      position: absolute;
      background: white;
      border-radius: var(--radius-md);
      box-shadow: var(--shadow-lg);
      padding: 10px 14px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .hero-float-badge-1 {
      bottom: -16px; left: -24px;
      animation: float-up 3s ease-in-out infinite;
    }
    .hero-float-badge-2 {
      top: -16px; right: -16px;
      background: var(--gold-500);
      color: white;
      animation: float-up 3s ease-in-out infinite .5s;
    }
    @keyframes float-up {
      0%,100% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
    }
    .hero-float-badge-icon { font-size: 1.5rem; }
    .hero-float-text-main { font-weight: 700; font-size: .85rem; color: var(--navy-700); }
    .hero-float-text-sub { font-size: .7rem; color: var(--gray-500); }
    .hero-float-badge-2 .hero-float-text-main { color: white; }
    .hero-float-badge-2 .hero-float-text-sub { color: rgba(255,255,255,.75); }
    .hero-scroll {
      position: absolute;
      bottom: 28px;
      left: 50%;
      transform: translateX(-50%);
      color: rgba(255,255,255,.3);
      font-size: 1.5rem;
      animation: bounce 2s ease infinite;
    }
    @keyframes bounce { 0%,100%{transform:translateX(-50%) translateY(0);} 50%{transform:translateX(-50%) translateY(8px);} }

    /* ============================================================
       ABOUT
    ============================================================ */
    .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; }
    .about-check-list { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin: 24px 0; }
    .about-check-item {
      display: flex;
      align-items: flex-start;
      gap: 8px;
      font-size: .875rem;
      color: var(--gray-600);
    }
    .check-icon { color: var(--gold-500); font-size: 1rem; flex-shrink: 0; margin-top: 1px; }
    .about-stats { display: flex; gap: 16px; margin-top: 28px; }
    .about-stat {
      text-align: center;
      padding: 16px 20px;
      background: var(--gray-50);
      border-radius: var(--radius-lg);
      flex: 1;
    }
    .about-stat-value { font-size: 1.8rem; font-weight: 700; color: var(--navy-700); }
    .about-stat-label { font-size: .75rem; color: var(--gray-500); margin-top: 4px; }
    .pillar-card {
      display: flex;
      gap: 16px;
      padding: 20px;
      border-radius: var(--radius-xl);
      border: 1px solid var(--gray-100);
      transition: var(--transition);
      margin-bottom: 14px;
    }
    .pillar-card:hover { box-shadow: var(--shadow-md); transform: translateX(4px); }
    .pillar-icon {
      width: 48px; height: 48px;
      border-radius: var(--radius-md);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      flex-shrink: 0;
      box-shadow: var(--shadow-sm);
    }
    .pillar-icon.blue  { background: linear-gradient(135deg,#3b82f6,#1d4ed8); }
    .pillar-icon.purple{ background: linear-gradient(135deg,#8b5cf6,#6d28d9); }
    .pillar-icon.gold  { background: linear-gradient(135deg,var(--gold-500),var(--gold-600)); }
    .pillar-title { font-weight: 600; color: var(--navy-700); margin-bottom: 4px; }
    .pillar-desc { font-size: .85rem; color: var(--gray-500); }
    .lang-card {
      padding: 20px;
      background: var(--navy-800);
      border-radius: var(--radius-xl);
      color: white;
      margin-top: 14px;
    }
    .lang-header { display: flex; align-items: center; gap: 8px; margin-bottom: 14px; font-weight: 600; }
    .lang-item { margin-bottom: 12px; }
    .lang-row { display: flex; justify-content: space-between; margin-bottom: 6px; font-size: .875rem; }
    .lang-level { color: rgba(255,255,255,.5); font-size: .8rem; }
    .lang-bar { height: 6px; background: rgba(255,255,255,.15); border-radius: var(--radius-full); overflow: hidden; }
    .lang-fill { height: 100%; background: var(--gold-400); border-radius: var(--radius-full); }

    /* ============================================================
       EXPERIENCE (TIMELINE)
    ============================================================ */
    .timeline { position: relative; max-width: 800px; margin: 0 auto; }
    .timeline::before {
      content: '';
      position: absolute;
      left: 31px; top: 0; bottom: 0;
      width: 2px;
      background: var(--gray-200);
    }
    .timeline-item { display: flex; gap: 24px; margin-bottom: 32px; }
    .timeline-dot {
      width: 64px; height: 64px;
      border-radius: var(--radius-md);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      position: relative;
      z-index: 2;
      font-size: .7rem;
      font-weight: 700;
      color: white;
      text-align: center;
      line-height: 1.2;
      box-shadow: var(--shadow-md);
    }
    .timeline-dot.gold   { background: linear-gradient(135deg, var(--gold-500), var(--gold-600)); }
    .timeline-dot.blue   { background: linear-gradient(135deg, #3b82f6, #1d4ed8); }
    .timeline-dot.navy   { background: linear-gradient(135deg, var(--navy-500), var(--navy-700)); }
    .timeline-card { flex: 1; }
    .timeline-card .card { padding: 24px; }
    .timeline-card-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 8px;
    }
    .timeline-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--navy-700);
    }
    .timeline-company { color: var(--gold-500); font-weight: 500; font-size: .9rem; }
    .timeline-desc { color: var(--gray-500); font-size: .875rem; margin: 8px 0 12px; }
    .timeline-tasks { list-style: none; }
    .timeline-tasks li {
      font-size: .875rem;
      color: var(--gray-600);
      padding: 4px 0;
      display: flex;
      align-items: flex-start;
      gap: 8px;
    }
    .timeline-tasks li::before {
      content: '▸';
      color: var(--gold-500);
      font-size: .85rem;
      flex-shrink: 0;
      margin-top: 1px;
    }
    .formation-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 48px; }
    .formation-card { padding: 24px; border-left: 4px solid var(--gold-500); }
    .formation-card.blue-border { border-color: var(--navy-500); }
    .formation-card-title {
      display: flex;
      align-items: center;
      gap: 8px;
      font-weight: 600;
      color: var(--navy-700);
      margin-bottom: 14px;
      font-size: .95rem;
    }
    .formation-item {
      padding-left: 12px;
      border-left: 2px solid var(--gray-100);
      margin-bottom: 12px;
    }
    .formation-year { font-size: .75rem; color: var(--gray-400); }
    .formation-degree { font-weight: 500; color: var(--navy-700); font-size: .875rem; }
    .formation-school { color: var(--gray-500); font-size: .8rem; }
    .cert-item {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: .875rem;
      color: var(--gray-600);
      padding: 3px 0;
    }
    .cert-check { color: var(--gold-500); font-weight: 700; }

    /* ============================================================
       CERTIFICATIONS
    ============================================================ */
    .cert-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
    .cert-pole {
      border-radius: var(--radius-xl);
      border: 1.5px solid var(--gray-200);
      overflow: hidden;
      transition: var(--transition);
    }
    .cert-pole:hover { box-shadow: var(--shadow-md); }
    .cert-pole-header {
      padding: 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      cursor: pointer;
      user-select: none;
      background: white;
    }
    .cert-pole-left { display: flex; align-items: center; gap: 12px; }
    .cert-pole-icon { font-size: 2rem; }
    .cert-pole-name { font-weight: 600; color: var(--navy-700); font-size: .9rem; }
    .cert-pole-count { font-size: .75rem; color: var(--gray-400); }
    .cert-pole-toggle { color: var(--gray-400); font-size: 1.1rem; transition: transform .3s; }
    .cert-pole.open .cert-pole-toggle { transform: rotate(180deg); }
    .cert-pole-body { display: none; padding: 0 20px 16px; background: white; }
    .cert-pole.open .cert-pole-body { display: block; }
    .cert-pole-item {
      display: flex;
      align-items: flex-start;
      gap: 8px;
      padding: 8px 0;
      border-top: 1px solid var(--gray-100);
      font-size: .8rem;
      color: var(--gray-600);
    }
    .cert-pole-item:first-child { border-top: none; }
    .cert-total {
      display: inline-flex;
      align-items: center;
      gap: 16px;
      background: var(--navy-800);
      color: white;
      padding: 20px 36px;
      border-radius: var(--radius-xl);
      margin-top: 40px;
    }
    .cert-total-num { font-size: 2.5rem; font-weight: 700; color: var(--gold-400); }
    .cert-total-label { font-size: 1rem; font-weight: 500; }
    .cert-total-sub { font-size: .8rem; color: rgba(255,255,255,.5); }
    .cert-orgs { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; margin-top: 20px; }

    /* ============================================================
       SKILLS
    ============================================================ */
    .skills-filters {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 8px;
      margin-bottom: 36px;
    }
    .skill-filter-btn {
      padding: 8px 18px;
      border-radius: var(--radius-full);
      font-size: .85rem;
      font-weight: 500;
      cursor: pointer;
      border: 1.5px solid var(--gray-200);
      background: white;
      color: var(--gray-600);
      transition: var(--transition);
    }
    .skill-filter-btn:hover, .skill-filter-btn.active {
      background: var(--navy-700);
      color: white;
      border-color: var(--navy-700);
      box-shadow: var(--shadow-sm);
    }
    .skills-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 14px; margin-bottom: 48px; }
    .skill-item {
      background: white;
      border: 1px solid var(--gray-100);
      border-radius: var(--radius-lg);
      padding: 16px;
      box-shadow: var(--shadow-sm);
      transition: var(--transition);
    }
    .skill-item:hover { box-shadow: var(--shadow-md); }
    .skill-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
    .skill-name { font-weight: 500; color: var(--navy-700); font-size: .875rem; }
    .skill-level-badge {
      font-size: .7rem;
      font-weight: 600;
      padding: 2px 8px;
      border-radius: var(--radius-full);
      color: white;
    }
    .level-expert   { background: var(--gold-500); }
    .level-advanced { background: #3b82f6; }
    .level-mid      { background: #22c55e; }
    .level-beginner { background: var(--gray-400); }
    .skill-pct { font-size: .7rem; color: var(--gray-400); text-align: right; margin-top: 4px; }
    .software-section h3 {
      text-align: center;
      font-weight: 600;
      color: var(--navy-700);
      font-size: 1.1rem;
      margin-bottom: 20px;
    }
    .software-tags { display: flex; flex-wrap: wrap; justify-content: center; gap: 10px; }
    .software-tag {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 16px;
      border-radius: var(--radius-full);
      font-size: .85rem;
      font-weight: 500;
      transition: var(--transition);
      cursor: default;
    }
    .software-tag:hover { transform: scale(1.05); }

    /* ============================================================
       SERVICES
    ============================================================ */
    .services-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; }
    .service-card { position: relative; overflow: hidden; }
    .service-card-top { height: 6px; }
    .service-card-body { padding: 28px; }
    .service-icon {
      width: 52px; height: 52px;
      border-radius: var(--radius-md);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.6rem;
      margin-bottom: 16px;
      box-shadow: var(--shadow-md);
      transition: transform .3s;
    }
    .service-card:hover .service-icon { transform: scale(1.1); }
    .service-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.05rem;
      font-weight: 600;
      color: var(--navy-700);
      margin-bottom: 8px;
    }
    .service-desc { font-size: .875rem; color: var(--gray-500); line-height: 1.6; margin-bottom: 14px; }
    .service-features { list-style: none; margin-bottom: 18px; }
    .service-features li {
      font-size: .8rem;
      color: var(--gray-600);
      padding: 4px 0;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .service-features li::before { content: '✓'; color: var(--gold-500); font-weight: 700; }
    .service-cta {
      font-size: .85rem;
      font-weight: 500;
      color: var(--navy-600);
      display: flex;
      align-items: center;
      gap: 4px;
      transition: color .2s;
    }
    .service-cta:hover { color: var(--gold-500); }
    .services-cta-banner {
      margin-top: 56px;
      background: linear-gradient(135deg, var(--navy-800), var(--navy-700));
      border-radius: var(--radius-xl);
      padding: 56px;
      text-align: center;
      color: white;
    }
    .services-cta-banner h3 {
      font-family: 'Playfair Display', serif;
      font-size: 1.75rem;
      margin-bottom: 12px;
    }
    .services-cta-banner p { color: rgba(255,255,255,.65); margin-bottom: 28px; }

    /* Gradient helpers */
    .grad-blue   { background: linear-gradient(135deg,#3b82f6,#1e3a5f); }
    .grad-green  { background: linear-gradient(135deg,#22c55e,#0d9488); }
    .grad-orange { background: linear-gradient(135deg,#f97316,#ef4444); }
    .grad-purple { background: linear-gradient(135deg,#8b5cf6,#4f46e5); }
    .grad-gold   { background: linear-gradient(135deg,var(--gold-500),#f97316); }

    /* ============================================================
       PORTFOLIO
    ============================================================ */
    .portfolio-filters {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 8px;
      margin-bottom: 36px;
    }
    .portfolio-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; }
    .project-card { cursor: pointer; }
    .project-thumb {
      height: 180px;
      position: relative;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      color: white;
    }
    .project-thumb-icon { font-size: 3.5rem; margin-bottom: 6px; }
    .project-thumb-cat { font-size: .8rem; opacity: .75; font-weight: 500; }
    .project-thumb-overlay {
      position: absolute;
      inset: 0;
      background: rgba(5,14,26,.8);
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transition: opacity .3s;
      color: white;
      font-weight: 600;
      font-size: .95rem;
      gap: 8px;
    }
    .project-card:hover .project-thumb-overlay { opacity: 1; }
    .project-body { padding: 20px; }
    .project-title-row { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 6px; }
    .project-title { font-weight: 600; color: var(--navy-700); font-size: .95rem; }
    .project-year { font-size: .75rem; color: var(--gray-400); flex-shrink: 0; }
    .project-card:hover .project-title { color: var(--gold-500); }
    .project-desc { font-size: .8rem; color: var(--gray-500); line-height: 1.5; margin-bottom: 12px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .project-tags { display: flex; flex-wrap: wrap; gap: 5px; }
    .project-tag {
      padding: 3px 8px;
      background: var(--gray-100);
      color: var(--gray-600);
      border-radius: var(--radius-full);
      font-size: .7rem;
      font-weight: 500;
    }

    /* Modal */
    .modal-backdrop {
      position: fixed;
      inset: 0;
      background: rgba(5,14,26,.85);
      backdrop-filter: blur(8px);
      z-index: 200;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 16px;
      opacity: 0;
      pointer-events: none;
      transition: opacity .3s;
    }
    .modal-backdrop.open { opacity: 1; pointer-events: all; }
    .modal {
      background: white;
      border-radius: var(--radius-xl);
      max-width: 660px;
      width: 100%;
      max-height: 90vh;
      overflow-y: auto;
      position: relative;
      transform: scale(.95) translateY(20px);
      transition: transform .3s;
    }
    .modal-backdrop.open .modal { transform: scale(1) translateY(0); }
    .modal-header { padding: 32px; position: relative; }
    .modal-close {
      position: absolute;
      top: 16px; right: 16px;
      width: 32px; height: 32px;
      border-radius: 50%;
      background: rgba(255,255,255,.2);
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      cursor: pointer;
      transition: background .2s;
    }
    .modal-close:hover { background: rgba(255,255,255,.35); }
    .modal-cat-year { font-size: .8rem; color: rgba(255,255,255,.65); font-weight: 500; text-transform: uppercase; letter-spacing: .05em; margin-bottom: 8px; }
    .modal-title { font-family: 'Playfair Display', serif; font-size: 1.5rem; font-weight: 700; color: white; margin-bottom: 8px; }
    .modal-desc { color: rgba(255,255,255,.75); font-size: .875rem; margin-bottom: 14px; }
    .modal-tags { display: flex; flex-wrap: wrap; gap: 6px; }
    .modal-tag { padding: 4px 12px; background: rgba(255,255,255,.18); color: white; border-radius: var(--radius-full); font-size: .75rem; font-weight: 500; }
    .modal-body { padding: 28px; }
    .modal-section { border-radius: var(--radius-lg); padding: 20px; margin-bottom: 14px; }
    .modal-section.blue   { background: #eff6ff; }
    .modal-section.gold   { background: #fffbeb; }
    .modal-section.green  { background: #f0fdf4; }
    .modal-section-title { font-weight: 600; color: var(--gray-700); margin-bottom: 12px; display: flex; align-items: center; gap: 8px; font-size: .95rem; }
    .modal-section ul { list-style: none; }
    .modal-section ul li {
      font-size: .85rem;
      color: var(--gray-600);
      padding: 4px 0;
      display: flex;
      align-items: flex-start;
      gap: 8px;
    }
    .modal-section ul li::before {
      content: '';
      width: 6px; height: 6px;
      border-radius: 50%;
      flex-shrink: 0;
      margin-top: 6px;
    }
    .modal-section.blue ul li::before { background: #3b82f6; }
    .modal-section.gold ul li::before { background: var(--gold-500); }
    .modal-section.green ul li::before { background: #22c55e; }

    /* ============================================================
       TESTIMONIALS
    ============================================================ */
    #testimonials { background: var(--navy-800); padding: 96px 0; }
    .testimonials-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.75rem, 4vw, 2.5rem);
      font-weight: 700;
      color: white;
      margin-bottom: 16px;
    }
    .testimonials-title .accent { color: var(--gold-400); }
    .testimonial-card {
      background: rgba(255,255,255,.05);
      border: 1px solid rgba(255,255,255,.1);
      border-radius: var(--radius-xl);
      padding: 40px;
      position: relative;
    }
    .testimonial-quote { font-size: 3rem; color: rgba(212,160,23,.25); line-height: 1; margin-bottom: 16px; }
    .testimonial-stars { display: flex; gap: 4px; margin-bottom: 20px; }
    .star { color: var(--gold-400); font-size: 1.1rem; }
    .testimonial-text { font-size: 1.1rem; color: rgba(255,255,255,.8); line-height: 1.7; font-style: italic; font-weight: 300; margin-bottom: 28px; }
    .testimonial-author { display: flex; align-items: center; gap: 12px; }
    .testimonial-avatar {
      width: 48px; height: 48px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--gold-500), var(--gold-600));
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      color: white;
      font-size: 1.1rem;
    }
    .testimonial-name { font-weight: 600; color: white; }
    .testimonial-role { font-size: .8rem; color: rgba(255,255,255,.5); }
    .testimonial-controls { display: flex; justify-content: center; align-items: center; gap: 14px; margin-top: 32px; }
    .testimonial-btn {
      width: 40px; height: 40px;
      border-radius: 50%;
      border: 1.5px solid rgba(255,255,255,.2);
      color: rgba(255,255,255,.6);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: var(--transition);
      font-size: 1rem;
      background: transparent;
    }
    .testimonial-btn:hover { border-color: rgba(255,255,255,.5); color: white; }
    .testimonial-dots { display: flex; gap: 8px; }
    .testimonial-dot {
      height: 8px;
      border-radius: var(--radius-full);
      background: rgba(255,255,255,.3);
      transition: var(--transition);
      cursor: pointer;
      border: none;
    }
    .testimonial-dot.active { width: 24px; background: var(--gold-400); }
    .testimonial-dot:not(.active) { width: 8px; }

    /* ============================================================
       CONTACT
    ============================================================ */
    .contact-grid { display: grid; grid-template-columns: 2fr 3fr; gap: 56px; align-items: start; }
    .contact-info-title { font-family: 'Playfair Display', serif; font-size: 1.3rem; font-weight: 700; color: var(--navy-700); margin-bottom: 10px; }
    .contact-info-desc { font-size: .875rem; color: var(--gray-500); line-height: 1.7; margin-bottom: 28px; }
    .contact-info-item { display: flex; align-items: center; gap: 14px; margin-bottom: 20px; }
    .contact-info-icon {
      width: 42px; height: 42px;
      background: rgba(212,160,23,.1);
      border-radius: var(--radius-md);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      flex-shrink: 0;
    }
    .contact-info-label { font-size: .7rem; color: var(--gray-400); text-transform: uppercase; letter-spacing: .08em; }
    .contact-info-value { font-size: .875rem; font-weight: 500; color: var(--navy-700); }
    .contact-info-value a { transition: color .2s; }
    .contact-info-value a:hover { color: var(--gold-500); }
    .contact-avail {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 14px 18px;
      background: #f0fdf4;
      border: 1px solid #bbf7d0;
      border-radius: var(--radius-md);
      margin-top: 24px;
    }
    .avail-dot { width: 10px; height: 10px; background: #22c55e; border-radius: 50%; animation: pulse-dot 2s infinite; }
    .avail-text { font-size: .85rem; color: #15803d; font-weight: 500; }
    .contact-form { background: white; border-radius: var(--radius-xl); padding: 36px; box-shadow: var(--shadow-md); border: 1px solid var(--gray-100); }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .submit-btn { width: 100%; justify-content: center; margin-top: 4px; }

    /* ============================================================
       FOOTER
    ============================================================ */
    footer {
      background: var(--navy-800);
      color: white;
      padding: 64px 0 0;
    }
    .footer-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 48px; padding-bottom: 48px; }
    .footer-brand-logo { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
    .footer-logo-icon {
      width: 36px; height: 36px;
      background: linear-gradient(135deg, var(--gold-500), var(--gold-600));
      border-radius: var(--radius-sm);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      color: white;
      font-size: .9rem;
    }
    .footer-logo-text { font-family: 'Playfair Display', serif; font-weight: 700; font-size: 1.1rem; }
    .footer-logo-text span { color: var(--gold-400); }
    .footer-brand-desc { font-size: .85rem; color: rgba(255,255,255,.5); line-height: 1.7; }
    .footer-col-title { font-size: .75rem; font-weight: 600; color: var(--gold-400); text-transform: uppercase; letter-spacing: .1em; margin-bottom: 16px; }
    .footer-links { list-style: none; }
    .footer-links li { margin-bottom: 8px; }
    .footer-links a { font-size: .85rem; color: rgba(255,255,255,.5); transition: color .2s; }
    .footer-links a:hover { color: var(--gold-400); }
    .footer-contact-item { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; font-size: .85rem; color: rgba(255,255,255,.5); }
    .footer-contact-icon { color: var(--gold-400); font-size: .9rem; }
    .footer-contact-item a { transition: color .2s; }
    .footer-contact-item a:hover { color: white; }
    .footer-bottom {
      border-top: 1px solid rgba(255,255,255,.08);
      padding: 20px 0;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 8px;
      font-size: .75rem;
      color: rgba(255,255,255,.35);
    }

    /* ============================================================
       ADMIN
    ============================================================ */
    #admin-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: linear-gradient(135deg, var(--navy-900), var(--navy-700));
      z-index: 300;
      overflow-y: auto;
    }
    #admin-overlay.open { display: block; }
    .admin-login-wrap {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }
    .admin-login-card {
      background: white;
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-xl);
      padding: 40px;
      width: 100%;
      max-width: 420px;
    }
    .admin-logo { text-align: center; margin-bottom: 28px; }
    .admin-logo-icon {
      width: 64px; height: 64px;
      background: linear-gradient(135deg, var(--navy-600), var(--navy-800));
      border-radius: var(--radius-lg);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.8rem;
      margin: 0 auto 14px;
      color: white;
      font-weight: 700;
    }
    .admin-logo-title { font-family: 'Playfair Display', serif; font-size: 1.4rem; font-weight: 700; color: var(--navy-700); }
    .admin-logo-sub { font-size: .85rem; color: var(--gray-400); margin-top: 4px; }

    /* Admin Dashboard */
    .admin-panel { display: none; }
    .admin-panel.open { display: block; }
    .admin-topbar {
      background: var(--navy-800);
