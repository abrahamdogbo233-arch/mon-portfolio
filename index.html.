const TYPEWRITER_WORDS = ["Marketing Digital","Intelligence Artificielle","E-commerce & SEO","Droit & Conformité"];
let twIndex=0, twChar=0, twDeleting=false;
function typewriterTick() {
  const el = document.getElementById('typewriter-word');
  if (!el) return;
  const word = TYPEWRITER_WORDS[twIndex];
  if (!twDeleting) {
    el.textContent = word.slice(0, ++twChar);
    if (twChar === word.length) { twDeleting=true; setTimeout(typewriterTick, 2000); return; }
  } else {
    el.textContent = word.slice(0, --twChar);
    if (twChar === 0) { twDeleting=false; twIndex=(twIndex+1)%TYPEWRITER_WORDS.length; }
  }
  setTimeout(typewriterTick, twDeleting ? 40 : 80);
}
typewriterTick();

