    color: document.getElementById('pf-color').value,
    tags: getTagsFromList('pf-tags-list'),
    objectives: getTagsFromList('pf-obj-list'),
    strategy: getTagsFromList('pf-strat-list'),
    results: getTagsFromList('pf-res-list')
  };
  if (editingProjectId) {
    const idx = state.projects.findIndex(p=>p.id===editingProjectId);
    if (idx>-1) state.projects[idx] = {...state.projects[idx],...proj};
  } else {
    proj.id = Date.now();
    state.projects.push(proj);
  }
  saveState();
  renderPortfolio();
  cancelProjectForm();
  renderAdminProjects();
  showAdminSection('projects');
}
function deleteProject(id) {
  state.projects = state.projects.filter(p=>p.id!==id);
  saveState();
  renderPortfolio();
  renderAdminProjects();
}

/* Tag input helpers */
function addTag(e, listId, inputId) {
  if (e.key==='Enter') { e.preventDefault(); addTagBtn(listId,inputId); }
}
function addTagBtn(listId, inputId) {
  const input = document.getElementById(inputId);
  const val = input.value.trim();
  if (!val) return;
  const list = document.getElementById(listId);
  // Avoid duplicates
  const existing = Array.from(list.querySelectorAll('.removable-tag')).map(el=>el.dataset.value);
  if (!existing.includes(val)) addTagToList(list, val);
  input.value='';
}
function addTagToList(listEl, val) {
  const span = document.createElement('span');
  span.className='removable-tag';
  span.dataset.value=val;
  span.innerHTML=`${val} <button onclick="this.parentElement.remove()" title="Supprimer">✕</button>`;
  listEl.appendChild(span);
}

/* ---- CERTIFICATIONS ADMIN ---- */
function renderAdminCertificates() {
  const list = document.getElementById('certs-admin-list');
  list.innerHTML = state.certifications.map(pole=>`
    <div class="admin-section" style="margin-bottom:14px;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
        <div style="display:flex;align-items:center;gap:10px;">
          <span style="font-size:1.8rem">${pole.icon}</span>
          <div>
            <div style="font-weight:600;color:var(--navy-700)">${pole.pole}</div>
            <div style="font-size:.75rem;color:var(--gray-400)">${pole.items.length} certifications</div>
          </div>
        </div>
        <button class="btn btn-primary btn-sm" onclick="addCertItem(${pole.id})">+ Ajouter</button>
      </div>
      <div id="cert-items-${pole.id}">
        ${pole.items.map((item,i)=>`
          <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:var(--gray-50);border-radius:var(--radius-md);margin-bottom:6px;">
            <span style="font-size:.85rem;color:var(--gray-700)">${item}</span>
            <button class="admin-action-btn del" onclick="removeCertItem(${pole.id},${i})" title="Supprimer">🗑</button>
          </div>
        `).join('')}
      </div>
    </div>
  `).join('');
}
function addCertItem(poleId) {
  const val = prompt('Nom de la certification :');
  if (!val || !val.trim()) return;
  const pole = state.certifications.find(c=>c.id===poleId);
  if (pole) { pole.items.push(val.trim()); saveState(); renderAdminCertificates(); }
}
function removeCertItem(poleId, index) {
  askDelete(()=>{
    const pole = state.certifications.find(c=>c.id===poleId);
    if (pole) { pole.items.splice(index,1); saveState(); renderAdminCertificates(); renderCertifications(); }
  });
}

/* ---- SKILLS ADMIN ---- */
function renderAdminSkills() {
  const list = document.getElementById('skills-admin-list');
  list.innerHTML = state.skills.map(s=>`
    <div class="skill-admin-row">
      <span class="skill-admin-name">${s.name}</span>
      <span class="badge badge-gray skill-admin-cat">${s.category}</span>
      <div class="skill-admin-bar"><div class="skill-admin-fill" style="width:${s.level}%"></div></div>
      <span class="skill-admin-pct">${s.level}%</span>
      <button class="admin-action-btn del" onclick="askDelete(()=>deleteSkill(${s.id}))">🗑</button>
    </div>
  `).join('') || '<p style="color:var(--gray-400);text-align:center;padding:12px">Aucune compétence.</p>';
  // Software
  const swList = document.getElementById('software-admin-list');
  swList.innerHTML = state.software.map((sw,i)=>`
    <span class="removable-tag" style="${SW_COLORS[i%SW_COLORS.length]}">
      ${sw.icon} ${sw.name}
      <button onclick="deleteSoftware('${sw.name}')" title="Supprimer">✕</button>
    </span>
  `).join('');
}
function toggleSkillForm() { document.getElementById('skill-form-panel').classList.toggle('open'); }
function saveSkill() {
  const name = document.getElementById('sf-name').value.trim();
  if (!name) return;
  state.skills.push({ id:Date.now(), name, category:document.getElementById('sf-cat').value, level:+document.getElementById('sf-level').value });
  saveState(); renderSkills(); renderAdminSkills();
  document.getElementById('sf-name').value='';
}
function deleteSkill(id) {
  state.skills = state.skills.filter(s=>s.id!==id);
  saveState(); renderSkills(); renderAdminSkills();
}
function toggleSoftwareForm() { document.getElementById('sw-form-panel').classList.toggle('open'); }
function saveSoftware() {
  const name = document.getElementById('sw-name').value.trim();
  const icon = document.getElementById('sw-icon').value.trim() || '🔧';
  if (!name) return;
  if (!state.software.find(s=>s.name===name)) {
    state.software.push({name,icon,color:'bg-gray'});
    saveState(); renderSoftware(); renderAdminSkills();
  }
  document.getElementById('sw-name').value='';
  document.getElementById('sw-icon').value='';
}
function deleteSoftware(name) {
  askDelete(()=>{
    state.software = state.software.filter(s=>s.name!==name);
    saveState(); renderSoftware(); renderAdminSkills();
  });
}

/* ---- CONFIRM DIALOG ---- */
function askDelete(cb) {
  deleteCallback = cb;
  document.getElementById('confirm-dialog').classList.add('open');
}
function confirmDelete() {
  if (deleteCallback) deleteCallback();
  deleteCallback=null;
  document.getElementById('confirm-dialog').classList.remove('open');
}
function cancelDelete() {
  deleteCallback=null;
  document.getElementById('confirm-dialog').classList.remove('open');
}

/* ============================================================
   INIT
============================================================ */
document.addEventListener('DOMContentLoaded', () => {
  renderCertifications();
  renderSkills();
  renderServices();
  renderPortfolio();
  renderTestimonial();
  initReveal();
  // Close modal on ESC
  document.addEventListener('keydown', e => {
    if (e.key==='Escape') {
      closeModalDirect();
      document.getElementById('admin-overlay').classList.remove('open');
      document.body.style.overflow='';
    }
  });
});
</script>
